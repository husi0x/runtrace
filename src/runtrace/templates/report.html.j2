<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ metadata.name }} · Runtrace Report</title>
  <style>
    :root {
      color-scheme: light;
      --page: #f7faff;
      --page-2: #f8fbff;
      --card: #ffffff;
      --text: #111827;
      --secondary: #475569;
      --muted: #64748b;
      --faint: #94a3b8;
      --border: #e2e8f0;
      --border-soft: #edf2f7;
      --blue: #2563eb;
      --blue-soft: #eef5ff;
      --green: #16a34a;
      --green-soft: #ecfdf3;
      --red: #dc2626;
      --red-soft: #fef2f2;
      --amber: #d97706;
      --amber-soft: #fffbeb;
      --shadow: 0 8px 30px rgba(15, 23, 42, 0.06);
      --shadow-soft: 0 1px 2px rgba(15, 23, 42, 0.04);
      --radius: 16px;
      --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      min-height: 100vh;
      font-family: var(--sans);
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.08), transparent 34rem),
        linear-gradient(180deg, var(--page) 0%, var(--page-2) 100%);
    }

    a { color: inherit; }
    code, pre { font-family: var(--mono); }

    .shell {
      width: min(1440px, calc(100% - 32px));
      min-height: calc(100vh - 32px);
      margin: 16px auto;
      display: grid;
      grid-template-columns: 260px minmax(0, 1fr);
      overflow: hidden;
      border: 1px solid var(--border);
      border-radius: 24px;
      background: var(--card);
      box-shadow: 0 22px 70px rgba(15, 23, 42, 0.08);
    }

    .sidebar {
      min-width: 0;
      padding: 22px 18px;
      border-right: 1px solid var(--border);
      background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 2px 6px 20px;
      font-weight: 760;
      letter-spacing: -0.02em;
    }

    .brand-icon, .card-icon, .section-icon {
      display: inline-grid;
      place-items: center;
      flex: 0 0 auto;
      width: 34px;
      height: 34px;
      border-radius: 11px;
      color: var(--blue);
      background: var(--blue-soft);
      border: 1px solid #dbeafe;
    }
    .icon {
      width: 17px;
      height: 17px;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
      fill: none;
    }
    .brand-icon .icon { width: 18px; height: 18px; }

    .nav {
      display: grid;
      gap: 6px;
      padding-bottom: 22px;
      border-bottom: 1px solid var(--border-soft);
    }

    .nav a {
      position: relative;
      display: flex;
      align-items: center;
      gap: 10px;
      min-height: 40px;
      padding: 10px 12px 10px 14px;
      border-radius: 12px;
      color: var(--secondary);
      text-decoration: none;
      font-size: 14px;
      font-weight: 650;
    }

    .nav a.active {
      color: var(--blue);
      background: var(--blue-soft);
    }

    .nav a.active::before {
      content: "";
      position: absolute;
      left: 0;
      top: 9px;
      bottom: 9px;
      width: 3px;
      border-radius: 99px;
      background: var(--blue);
    }

    .details {
      padding: 22px 6px 0;
    }

    .details-title {
      margin: 0 0 14px;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--faint);
    }

    .detail-item { margin-bottom: 14px; }
    .detail-label {
      display: block;
      margin-bottom: 4px;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .detail-value {
      display: block;
      min-width: 0;
      color: #1f2937;
      font-size: 13px;
      font-weight: 620;
      line-height: 1.5;
      overflow-wrap: anywhere;
    }
    .detail-value.code-pill {
      padding: 9px 10px;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #f8fafc;
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 560;
      color: #334155;
    }

    .content {
      min-width: 0;
      padding: 28px 32px 34px;
      background: linear-gradient(180deg, #fbfdff 0%, #f8fbff 100%);
    }

    .header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 18px;
      padding-bottom: 22px;
      border-bottom: 1px solid var(--border);
    }

    h1 {
      margin: 0;
      font-size: clamp(30px, 4vw, 44px);
      line-height: 1.06;
      letter-spacing: -0.045em;
      font-weight: 800;
    }
    .run-name {
      display: inline-block;
      margin-left: 10px;
      color: var(--blue);
    }
    .header-meta {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 10px;
      color: var(--muted);
      font-size: 13px;
      text-align: right;
    }

    .button-link, .status-pill, .hash-pill, .change-pill, .check-pill {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      border-radius: 999px;
      white-space: nowrap;
    }

    .button-link {
      min-height: 36px;
      padding: 8px 12px;
      border: 1px solid var(--border);
      background: #fff;
      color: var(--secondary);
      text-decoration: none;
      font-weight: 700;
      box-shadow: var(--shadow-soft);
    }
    .button-link:hover { border-color: #bfdbfe; color: var(--blue); }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 16px;
      margin-top: 24px;
    }

    .card, .panel {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--card);
      box-shadow: var(--shadow);
    }
    .card { grid-column: span 2; padding: 20px; }
    .card.command-card { grid-column: span 6; }
    .card-top {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
    }
    .card-icon { width: 32px; height: 32px; border-radius: 10px; }
    .label {
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.075em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .value {
      color: var(--text);
      font-size: 24px;
      line-height: 1.18;
      font-weight: 780;
      letter-spacing: -0.035em;
      overflow-wrap: anywhere;
    }
    .value.command {
      max-height: 104px;
      padding: 10px 11px;
      overflow: auto;
      border: 1px solid var(--border-soft);
      border-radius: 10px;
      background: #f8fafc;
      font-family: var(--mono);
      font-size: 12.5px;
      line-height: 1.5;
      font-weight: 600;
      letter-spacing: 0;
      color: #1e293b;
    }
    .exit-success { color: var(--green); }
    .exit-failure { color: var(--red); }
    .git-state {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 2px;
    }
    .hash-pill {
      padding: 6px 8px;
      background: #f8fafc;
      border: 1px solid var(--border);
      color: #334155;
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 700;
    }
    .arrow { color: var(--muted); }

    .panel {
      margin-top: 18px;
      padding: 22px;
    }
    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      margin-bottom: 18px;
    }
    .title-group {
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
    }
    h2 {
      margin: 0;
      font-size: 20px;
      letter-spacing: -0.035em;
    }
    .hint {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 13px;
    }
    .status-pill {
      padding: 7px 10px;
      border: 1px solid var(--border);
      background: #f8fafc;
      color: var(--secondary);
      font-size: 12px;
      font-weight: 750;
    }

    .table-wrap { overflow-x: auto; }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    th {
      padding: 0 12px 10px;
      color: var(--muted);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }
    td {
      padding: 14px 12px;
      border-bottom: 1px solid var(--border-soft);
      color: var(--secondary);
      vertical-align: middle;
    }
    tr:last-child td { border-bottom: 0; }
    .index-cell { width: 56px; color: var(--faint); font-variant-numeric: tabular-nums; }
    .file-path {
      font-family: var(--mono);
      font-size: 13px;
      font-weight: 600;
      color: #1e293b;
      overflow-wrap: anywhere;
    }
    .change-pill {
      padding: 6px 10px;
      background: var(--blue-soft);
      color: var(--blue);
      font-size: 12px;
      font-weight: 800;
    }
    .change-dot, .legend-dot {
      display: inline-block;
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: var(--blue);
    }
    .change-pill.added { background: var(--green-soft); color: var(--green); }
    .change-pill.deleted { background: var(--red-soft); color: var(--red); }
    .change-pill.added .change-dot { background: var(--green); }
    .change-pill.deleted .change-dot { background: var(--red); }

    .diff-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 20px;
      align-items: center;
    }
    .diff-count {
      margin-bottom: 12px;
      color: var(--secondary);
      font-size: 14px;
      font-weight: 700;
    }
    .stat-bar {
      display: flex;
      width: 100%;
      height: 14px;
      overflow: hidden;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: #f1f5f9;
    }
    .stat-insert { background: var(--green); min-width: 0; }
    .stat-delete { background: var(--red); min-width: 0; }
    .diff-summary {
      display: grid;
      gap: 8px;
      min-width: 170px;
      color: var(--secondary);
      font-size: 14px;
      font-weight: 700;
    }
    .legend-dot.green { background: var(--green); }
    .legend-dot.red { background: var(--red); }

    .checklist { display: grid; gap: 10px; }
    .check-row {
      display: grid;
      grid-template-columns: 26px minmax(0, 1fr) auto;
      gap: 12px;
      align-items: center;
      padding: 13px 14px;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: #fff;
    }
    .checkbox {
      display: inline-grid;
      place-items: center;
      width: 20px;
      height: 20px;
      border-radius: 6px;
      border: 1.5px solid #cbd5e1;
      color: transparent;
      font-size: 13px;
      font-weight: 900;
    }
    .checkbox.done {
      border-color: var(--blue);
      background: var(--blue);
      color: #fff;
    }
    .check-title { font-weight: 760; color: #1f2937; letter-spacing: -0.015em; }
    .check-detail { margin-top: 2px; color: var(--muted); font-size: 13px; line-height: 1.4; }
    .check-pill {
      padding: 6px 10px;
      font-size: 12px;
      font-weight: 800;
      background: #f1f5f9;
      color: var(--muted);
    }
    .check-pill.done { background: var(--green-soft); color: var(--green); }
    .check-pill.review { background: var(--amber-soft); color: var(--amber); }
    .check-pill.fail { background: var(--red-soft); color: var(--red); }

    pre {
      margin: 0;
      max-height: 420px;
      padding: 16px;
      overflow: auto;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: #f8fafc;
      color: #334155;
      font-size: 13px;
      line-height: 1.6;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
    }
    .empty {
      padding: 18px;
      border: 1px dashed #cbd5e1;
      border-radius: 14px;
      background: #f8fafc;
      color: var(--muted);
      font-size: 14px;
    }
    .inline-time {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      min-height: 36px;
      padding: 8px 10px;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: #fff;
      color: var(--secondary);
      font-weight: 700;
      box-shadow: var(--shadow-soft);
    }
    .footer-note {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 18px;
      padding: 14px 16px;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: #fff;
      color: var(--muted);
      font-size: 13px;
      box-shadow: var(--shadow-soft);
    }
    .footer-note a { color: var(--blue); font-weight: 750; text-decoration: none; }
    .footer-note a:hover { text-decoration: underline; }

    @media (max-width: 1080px) {
      .shell { grid-template-columns: 1fr; }
      .sidebar { border-right: 0; border-bottom: 1px solid var(--border); }
      .nav { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .details { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); column-gap: 16px; }
      .details-title { grid-column: 1 / -1; }
      .summary-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .card, .card.command-card { grid-column: auto; }
    }
    @media (max-width: 720px) {
      .shell { width: 100%; min-height: 100vh; margin: 0; border-radius: 0; border-left: 0; border-right: 0; }
      .content, .sidebar { padding: 20px; }
      .header, .panel-head, .diff-layout { grid-template-columns: 1fr; flex-direction: column; align-items: flex-start; }
      .header-meta { justify-content: flex-start; text-align: left; }
      .summary-grid, .details { grid-template-columns: 1fr; }
      .card, .card.command-card { grid-column: auto; }
      .nav { grid-template-columns: 1fr; }
      .check-row { grid-template-columns: 26px minmax(0, 1fr); }
      .check-pill { grid-column: 2; width: max-content; }
    }
  </style>
</head>
<body>
  <svg aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden">
  <symbol id="i-report" viewBox="0 0 24 24"><path d="M8 3h8l4 4v14H4V3h4z"/><path d="M16 3v5h5"/><path d="M8 13h8M8 17h5"/></symbol>
  <symbol id="i-terminal" viewBox="0 0 24 24"><path d="m4 7 5 5-5 5"/><path d="M12 19h8"/></symbol>
  <symbol id="i-clock" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></symbol>
  <symbol id="i-check" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></symbol>
  <symbol id="i-alert" viewBox="0 0 24 24"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.3 4.3 2.8 18a2 2 0 0 0 1.8 3h14.8a2 2 0 0 0 1.8-3L13.7 4.3a2 2 0 0 0-3.4 0Z"/></symbol>
  <symbol id="i-git" viewBox="0 0 24 24"><circle cx="6" cy="6" r="2"/><circle cx="18" cy="18" r="2"/><circle cx="6" cy="18" r="2"/><path d="M8 6h3a3 3 0 0 1 3 3v6"/><path d="M8 18h8"/></symbol>
  <symbol id="i-files" viewBox="0 0 24 24"><path d="M7 3h7l4 4v14H7z"/><path d="M14 3v5h5"/><path d="M5 7H4a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h10"/></symbol>
  <symbol id="i-chart" viewBox="0 0 24 24"><path d="M4 19V5"/><path d="M4 19h16"/><path d="M8 16v-5"/><path d="M12 16V8"/><path d="M16 16v-3"/></symbol>
  <symbol id="i-list-check" viewBox="0 0 24 24"><path d="m3 7 2 2 4-4"/><path d="M12 7h8"/><path d="m3 17 2 2 4-4"/><path d="M12 17h8"/></symbol>
  <symbol id="i-log" viewBox="0 0 24 24"><path d="M5 4h14v16H5z"/><path d="M8 8h8M8 12h8M8 16h5"/></symbol>
  <symbol id="i-info" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 11v5"/><path d="M12 8h.01"/></symbol>
</svg>
  <div class="shell">
    <aside class="sidebar">
      <div class="brand"><span class="brand-icon"><svg class="icon" aria-hidden="true" focusable="false"><use href="#i-report"></use></svg></span><span>Runtrace Report</span></div>
      <nav class="nav" aria-label="Report sections">
        <a class="active" href="#summary">Summary</a>
        <a href="#files">Files</a>
        <a href="#raw-log">Raw Log</a>
      </nav>
      <div class="details">
        <h3 class="details-title">Run Details</h3>
        <div class="detail-item"><span class="detail-label">Run ID</span><span class="detail-value code-pill">{{ metadata.run_id }}</span></div>
        <div class="detail-item"><span class="detail-label">Started</span><span class="detail-value">{{ view.started_display }}</span></div>
        <div class="detail-item"><span class="detail-label">Finished</span><span class="detail-value">{{ view.finished_display }}</span></div>
        <div class="detail-item"><span class="detail-label">Report Path</span><span class="detail-value code-pill">{{ view.report_path }}</span></div>
        <div class="detail-item"><span class="detail-label">Git Branch</span><span class="detail-value">{{ view.branch }}</span></div>
        <div class="detail-item"><span class="detail-label">Repository</span><span class="detail-value">{{ view.repository_name }}</span><span class="detail-value code-pill" style="margin-top:6px">{{ view.repository }}</span></div>
        <div class="detail-item"><span class="detail-label">Run by</span><span class="detail-value">{{ view.run_by }}</span></div>
        <div class="detail-item"><span class="detail-label">Agent</span><span class="detail-value">{{ view.agent }}</span></div>
        <div class="detail-item"><span class="detail-label">Version</span><span class="detail-value">{{ view.version }}</span></div>
      </div>
    </aside>

    <main class="content">
      <header class="header">
        <div>
          <h1>Run Report <span class="run-name">{{ metadata.name }}</span></h1>
          <div class="hint">Standalone local report for command output, git state, file changes, and review signals.</div>
        </div>
        <div class="header-meta">
          <span class="inline-time"><svg class="icon" aria-hidden="true" focusable="false"><use href="#i-clock"></use></svg>{{ view.started_display }}</span>
          <a class="button-link" href="output.log">Open Raw Log</a>
        </div>
      </header>

      <section id="summary" class="summary-grid" aria-label="Run summary">
        <div class="card command-card">
          <div class="card-top"><span class="card-icon"><svg class="icon" aria-hidden="true" focusable="false"><use href="#i-terminal"></use></svg></span><span class="label">Command</span></div>
          <div class="value command">{{ metadata.command_shell }}</div>
        </div>
        <div class="card">
          <div class="card-top"><span class="card-icon"><svg class="icon" aria-hidden="true" focusable="false"><use href="#i-clock"></use></svg></span><span class="label">Duration</span></div>
          <div class="value">{{ view.duration_display }}</div>
        </div>
        <div class="card">
          <div class="card-top"><span class="card-icon"><svg class="icon" aria-hidden="true" focusable="false"><use href="{{ '#i-check' if metadata.succeeded else '#i-alert' }}"></use></svg></span><span class="label">Exit Code</span></div>
          <div class="value {{ 'exit-success' if metadata.succeeded else 'exit-failure' }}">{{ metadata.exit_code }}</div>
        </div>
        <div class="card">
          <div class="card-top"><span class="card-icon"><svg class="icon" aria-hidden="true" focusable="false"><use href="#i-git"></use></svg></span><span class="label">Git State</span></div>
          <div class="git-state"><span class="hash-pill">{{ view.before_sha }}</span><span class="arrow">→</span><span class="hash-pill">{{ view.after_sha }}</span></div>
        </div>
      </section>

      <section id="files" class="panel">
        <div class="panel-head">
          <div>
            <div class="title-group"><span class="section-icon"><svg class="icon" aria-hidden="true" focusable="false"><use href="#i-files"></use></svg></span><h2>Changed Files</h2></div>
            <p class="hint">Files touched after the command finished.</p>
          </div>
          <span class="status-pill">{{ metadata.changed_files|length }} files</span>
        </div>
        {% if view.changed_file_rows %}
        <div class="table-wrap">
          <table>
            <thead><tr><th>#</th><th>File path</th><th>Change type</th></tr></thead>
            <tbody>
              {% for row in view.changed_file_rows %}
              <tr>
                <td class="index-cell">{{ row.index }}</td>
                <td><span class="file-path">{{ row.path }}</span></td>
                <td><span class="change-pill {{ row.change_type|lower }}"><span class="change-dot"></span>{{ row.change_type }}</span></td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% else %}
        <div class="empty">No changed files detected.</div>
        {% endif %}
      </section>

      <section class="panel">
        <div class="panel-head">
          <div>
            <div class="title-group"><span class="section-icon"><svg class="icon" aria-hidden="true" focusable="false"><use href="#i-chart"></use></svg></span><h2>Diff Stat</h2></div>
            <p class="hint">Compact summary of insertions and deletions.</p>
          </div>
        </div>
        <div class="diff-layout">
          <div>
            <div class="diff-count">{{ view.diff.files_changed or metadata.changed_files|length }} files changed</div>
            <div class="stat-bar" aria-label="Diff stat bar">
              {% if view.diff.insertions or view.diff.deletions %}
              <div class="stat-insert" style="width: {{ view.diff.insert_pct }}%"></div>
              <div class="stat-delete" style="width: {{ view.diff.delete_pct }}%"></div>
              {% else %}
              <div class="stat-insert" style="width: 0%"></div>
              {% endif %}
            </div>
          </div>
          <div class="diff-summary">
            <span><span class="legend-dot green"></span> {{ view.diff.insertions }} insertions(+)</span>
            <span><span class="legend-dot red"></span> {{ view.diff.deletions }} deletions(-)</span>
          </div>
        </div>
        {% if metadata.diff_stat_after %}<pre style="margin-top:16px">{{ metadata.diff_stat_after }}</pre>{% endif %}
      </section>

      <section class="panel">
        <div class="panel-head">
          <div>
            <div class="title-group"><span class="section-icon"><svg class="icon" aria-hidden="true" focusable="false"><use href="#i-list-check"></use></svg></span><h2>Review checklist</h2></div>
            <p class="hint">Existing Runtrace review signals, displayed as an actionable checklist.</p>
          </div>
        </div>
        <div class="checklist">
          {% for row in view.review_rows %}
          <div class="check-row">
            <span class="checkbox {{ 'done' if row.done else '' }}">{% if row.done %}<svg class="icon" aria-hidden="true" focusable="false"><use href="#i-check"></use></svg>{% endif %}</span>
            <div>
              <div class="check-title">{{ row.title }}</div>
              <div class="check-detail">{{ row.detail }}</div>
            </div>
            <span class="check-pill {{ row.tone }}">{{ row.state }}</span>
          </div>
          {% endfor %}
        </div>
      </section>

      <section id="raw-log" class="panel">
        <div class="panel-head">
          <div>
            <div class="title-group"><span class="section-icon"><svg class="icon" aria-hidden="true" focusable="false"><use href="#i-log"></use></svg></span><h2>Raw Log</h2></div>
            <p class="hint">Full output is saved next to this report as output.log.</p>
          </div>
          <a class="button-link" href="output.log">open output.log</a>
        </div>
        <pre>{{ metadata.output_preview[-3000:] or 'No command output captured.' }}</pre>
      </section>

      <div class="footer-note"><svg class="icon" aria-hidden="true" focusable="false"><use href="#i-info"></use></svg>Full output and logs are available in the <a href="#raw-log">Raw Log</a> section.</div>
    </main>
  </div>
</body>
</html>
