<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Runtrace index</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #070a12;
      --panel: rgba(16, 24, 39, 0.92);
      --panel-2: rgba(10, 15, 28, 0.9);
      --border: rgba(148, 163, 184, 0.18);
      --text: #f8fafc;
      --muted: #b6c2d1;
      --faint: #8ea0b5;
      --green: #22c55e;
      --red: #fb7185;
      --blue: #60a5fa;
      --shadow: 0 24px 70px rgba(0, 0, 0, 0.38);
      --radius: 22px;
      --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
      --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      font-family: var(--sans);
      background:
        radial-gradient(circle at 18% -8%, rgba(96, 165, 250, 0.18), transparent 34rem),
        linear-gradient(180deg, #080b14 0%, #070a12 100%);
      color: var(--text);
    }
    main { width: min(1180px, calc(100% - 32px)); margin: 0 auto; padding: 32px 0 56px; }
    .hero, section {
      border: 1px solid var(--border);
      border-radius: 30px;
      background: linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(9, 14, 26, 0.96));
      box-shadow: var(--shadow);
    }
    .hero { padding: 30px; }
    .brand { display: inline-flex; align-items: center; gap: 10px; color: #cbd5e1; font-weight: 700; }
    .logo { display: grid; place-items: center; width: 34px; height: 34px; border-radius: 11px; background: rgba(96, 165, 250, 0.22); font-family: var(--mono); }
    h1 { margin: 20px 0 0; font-size: clamp(34px, 5vw, 60px); line-height: 1; letter-spacing: -0.06em; }
    .subtitle { max-width: 740px; margin: 16px 0 0; color: var(--muted); line-height: 1.65; }
    section { margin-top: 16px; padding: 18px; background: var(--panel); }
    table { width: 100%; border-collapse: collapse; }
    th { color: var(--faint); font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; text-align: left; }
    th, td { padding: 12px; border-bottom: 1px solid var(--border); vertical-align: top; }
    td { color: #dbe4ef; font-size: 14px; }
    code { font-family: var(--mono); color: #dbeafe; overflow-wrap: anywhere; }
    a { color: var(--blue); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .badge { display: inline-flex; border-radius: 999px; padding: 5px 9px; font-size: 12px; font-weight: 800; text-transform: uppercase; }
    .badge.success { background: rgba(34, 197, 94, 0.12); color: var(--green); }
    .badge.failed { background: rgba(251, 113, 133, 0.13); color: var(--red); }
    .muted { color: var(--muted); }
    .empty { padding: 18px; color: var(--muted); border: 1px dashed rgba(148, 163, 184, 0.28); border-radius: 18px; }
    @media (max-width: 860px) {
      main { width: min(100% - 20px, 1180px); padding-top: 14px; }
      .hero { padding: 22px; border-radius: 24px; }
      table, thead, tbody, th, td, tr { display: block; }
      thead { display: none; }
      tr { padding: 12px 0; border-bottom: 1px solid var(--border); }
      td { border: 0; padding: 6px 0; }
    }
  </style>
</head>
<body>
<main>
  <header class="hero">
    <div class="brand"><span class="logo">rt</span> Runtrace</div>
    <h1>Run index</h1>
    <p class="subtitle">All local Runtrace runs in this project, newest first. Reports and logs stay local under <code>.runtrace/</code>.</p>
  </header>

  <section>
    {% if runs %}
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Run ID</th>
            <th>Status</th>
            <th>Command</th>
            <th>Duration</th>
            <th>Created</th>
            <th>Changed</th>
            <th>Links</th>
          </tr>
        </thead>
        <tbody>
        {% for run in runs %}
          <tr>
            <td>{{ run.name }}</td>
            <td><code>{{ run.run_id }}</code></td>
            <td><span class="badge {{ run.status }}">{{ run.status }}</span></td>
            <td><code>{{ run.command }}</code></td>
            <td>{{ run.duration }}s</td>
            <td>{{ run.created }}</td>
            <td>{{ run.changed_file_count }}</td>
            <td>
              {% if run.report_href %}<a href="{{ run.report_href }}">report.html</a>{% else %}<span class="muted">report not generated yet</span>{% endif %}
              {% if run.output_href %}<br><a href="{{ run.output_href }}">output.log</a>{% endif %}
            </td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% else %}
      <div class="empty">No runs found yet. Try: <code>runtrace demo</code></div>
    {% endif %}
  </section>
</main>
</body>
</html>
